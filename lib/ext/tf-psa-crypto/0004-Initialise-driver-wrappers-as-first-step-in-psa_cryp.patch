From 05f5ed8272e9ee0bf9dd3dbbdc4f97183670b5e8 Mon Sep 17 00:00:00 2001
From: Antonio de Angelis <Antonio.deAngelis@arm.com>
Date: Thu, 12 Mar 2026 13:41:43 +0000
Subject: [PATCH 04/17] Initialise driver wrappers as first step in
 psa_crypto_init()

This patch amends the order of initialisations performed in
psa_crypto_init() to make sure that the driver wrappers based
on the PSA driver API are initialised just after the key slots
in memory, both of them at the beginning of the initialisation
sequence.

Signed-off-by: Antonio de Angelis <antonio.deangelis@arm.com>
---
 core/psa_crypto.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/core/psa_crypto.c b/core/psa_crypto.c
index ccd59bfac..9981bb447 100644
--- a/core/psa_crypto.c
+++ b/core/psa_crypto.c
@@ -8892,12 +8892,12 @@ psa_status_t psa_crypto_init(void)
         return PSA_SUCCESS;
     }
 
-    status = mbedtls_psa_crypto_init_subsystem(PSA_CRYPTO_SUBSYSTEM_DRIVER_WRAPPERS);
+    status = mbedtls_psa_crypto_init_subsystem(PSA_CRYPTO_SUBSYSTEM_KEY_SLOTS);
     if (status != PSA_SUCCESS) {
         goto exit;
     }
 
-    status = mbedtls_psa_crypto_init_subsystem(PSA_CRYPTO_SUBSYSTEM_KEY_SLOTS);
+    status = mbedtls_psa_crypto_init_subsystem(PSA_CRYPTO_SUBSYSTEM_DRIVER_WRAPPERS);
     if (status != PSA_SUCCESS) {
         goto exit;
     }
-- 
2.34.1


From 3ff0147013c2454d0cea3252cf38b71133cb436b Mon Sep 17 00:00:00 2001
From: Tamas Ban <tamas.ban@arm.com>
Date: Thu, 12 Mar 2026 13:41:43 +0000
Subject: [PATCH 03/17] Enable crypto code sharing between independent binaries

Signed-off-by: Tamas Ban <tamas.ban@arm.com>
---
 drivers/code_share.c     | 3 +++
 platform/platform.c      | 4 ++--
 platform/platform_util.c | 2 +-
 3 files changed, 6 insertions(+), 3 deletions(-)
 create mode 100644 drivers/code_share.c

diff --git a/drivers/code_share.c b/drivers/code_share.c
new file mode 100644
index 000000000..fd6dfe503
--- /dev/null
+++ b/drivers/code_share.c
@@ -0,0 +1,3 @@
+/* This is a deliberately empty file just to check whether the patch for enabling
+ * extensive crypto code sharing was already applied on the tf-psa-crypto library.
+ */
diff --git a/platform/platform.c b/platform/platform.c
index 204458c46..215a49037 100644
--- a/platform/platform.c
+++ b/platform/platform.c
@@ -41,8 +41,8 @@ static void platform_free_uninit(void *ptr)
 #define MBEDTLS_PLATFORM_STD_FREE     platform_free_uninit
 #endif /* !MBEDTLS_PLATFORM_STD_FREE */
 
-static void * (*mbedtls_calloc_func)(size_t, size_t) = MBEDTLS_PLATFORM_STD_CALLOC;
-static void (*mbedtls_free_func)(void *) = MBEDTLS_PLATFORM_STD_FREE;
+void * (*mbedtls_calloc_func)(size_t, size_t) = MBEDTLS_PLATFORM_STD_CALLOC;
+void (*mbedtls_free_func)(void *) = MBEDTLS_PLATFORM_STD_FREE;
 
 void *mbedtls_calloc(size_t nmemb, size_t size)
 {
diff --git a/platform/platform_util.c b/platform/platform_util.c
index 3dd58f3aa..98904fd54 100644
--- a/platform/platform_util.c
+++ b/platform/platform_util.c
@@ -72,7 +72,7 @@
 #if !defined(MBEDTLS_PLATFORM_HAS_EXPLICIT_BZERO) && !(defined(__STDC_LIB_EXT1__) && \
     !defined(__IAR_SYSTEMS_ICC__)) \
     && !defined(_WIN32)
-static void *(*const volatile memset_func)(void *, int, size_t) = memset;
+void *(*const volatile memset_func)(void *, int, size_t) = memset;
 #endif
 
 void mbedtls_platform_zeroize(void *buf, size_t len)
-- 
2.34.1


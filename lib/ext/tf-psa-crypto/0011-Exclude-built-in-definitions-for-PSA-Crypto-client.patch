From 1861feec1205cb72edb171766be3e24b1314f3d0 Mon Sep 17 00:00:00 2001
From: David Vincze <david.vincze@arm.com>
Date: Thu, 12 Mar 2026 13:41:43 +0000
Subject: [PATCH 11/17] Exclude built-in definitions for PSA Crypto client

Do not include context definitions or additional symbols used by
built-in crypto modules/drivers for a PSA Crypto client. These are
not needed when a client is built with the MBEDTLS_PSA_CRYPTO_CLIENT
configuration option enabled, and excluding them prevents unnecessary
build errors due to missing private dependencies.

Signed-off-by: David Vincze <david.vincze@arm.com>
---
 include/psa/crypto_struct.h        | 6 ++++++
 include/tf-psa-crypto/build_info.h | 2 ++
 2 files changed, 8 insertions(+)

diff --git a/include/psa/crypto_struct.h b/include/psa/crypto_struct.h
index 063808743..d283875b7 100644
--- a/include/psa/crypto_struct.h
+++ b/include/psa/crypto_struct.h
@@ -56,9 +56,11 @@ extern "C" {
 
 #include "tf-psa-crypto/build_info.h"
 
+#if defined(MBEDTLS_PSA_CRYPTO_C)
 /* Include the context definition for the compiled-in drivers for the primitive
  * algorithms. */
 #include "psa/crypto_driver_contexts_primitives.h"
+#endif
 
 struct psa_hash_operation_s {
 #if defined(MBEDTLS_PSA_CRYPTO_CLIENT) && !defined(MBEDTLS_PSA_CRYPTO_C)
@@ -153,9 +155,11 @@ static inline struct psa_cipher_operation_s psa_cipher_operation_init(void)
     return v;
 }
 
+#if defined(MBEDTLS_PSA_CRYPTO_C)
 /* Include the context definition for the compiled-in drivers for the composite
  * algorithms. */
 #include "psa/crypto_driver_contexts_composites.h"
+#endif
 
 /* Include context definitions from the PQCP driver.
  * (There are none yet at the time of writing, that will come with multipart
@@ -232,9 +236,11 @@ static inline struct psa_aead_operation_s psa_aead_operation_init(void)
     return v;
 }
 
+#if defined(MBEDTLS_PSA_CRYPTO_C)
 /* Include the context definition for the compiled-in drivers for the key
  * derivation algorithms. */
 #include "psa/crypto_driver_contexts_key_derivation.h"
+#endif
 
 struct psa_key_derivation_s {
 #if defined(MBEDTLS_PSA_CRYPTO_CLIENT) && !defined(MBEDTLS_PSA_CRYPTO_C)
diff --git a/include/tf-psa-crypto/build_info.h b/include/tf-psa-crypto/build_info.h
index 611e96d47..b1ab8acb5 100644
--- a/include/tf-psa-crypto/build_info.h
+++ b/include/tf-psa-crypto/build_info.h
@@ -169,8 +169,10 @@
 /* Define additional symbols used by support modules. */
 #include "tf-psa-crypto/private/crypto_adjust_config_support.h"
 
+#if defined(MBEDTLS_PSA_CRYPTO_C)
 /* Define additional symbols used by built-in crypto modules. */
 #include "mbedtls/private/crypto_adjust_config_tweak_builtins.h"
+#endif
 
 #if defined(TF_PSA_CRYPTO_TEST_LIBTESTDRIVER1)
 #include "mbedtls/private/libtestdriver1-crypto_adjust_config_tweak_builtins.h"
-- 
2.34.1

